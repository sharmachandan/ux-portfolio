---
interface Props {
  name: string;
  year: number;
  category: string;
  project: string;
  org?: string;
  link?: string;
}

const { name, year, category, project, org, link } = Astro.props;
---

<div class="rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-6 transition-all duration-[var(--transition-base)] hover:border-[rgb(var(--color-accent))]/40 hover:shadow-glow">
  <p class="text-sm font-medium text-[rgb(var(--color-accent))]">{year} · {org || 'Award'}</p>
  <h3 class="mt-2 font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">{name}</h3>
  <p class="mt-1 text-sm text-[rgb(var(--color-text-muted))]">{category}</p>
  <p class="mt-2 text-sm text-[rgb(var(--color-text-muted))]">Project: {project}</p>
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-block text-sm font-medium text-[rgb(var(--color-accent))] hover:underline"
    >
      View award →
    </a>
  )}
</div>
