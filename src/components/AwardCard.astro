---
interface Props {
  name: string;
  year: number;
  category: string;
  project: string;
  org?: string;
  link?: string;
  imageSrc?: string;
}

const { name, year, category, project, org, link, imageSrc } = Astro.props;
---

<div class="border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-6 transition-all duration-[var(--transition-base)] hover:-translate-y-1 hover:border-[rgb(var(--color-accent-muted))]/30 hover:shadow-md">
  {imageSrc && (
    <div class="-mx-6 -mt-6 mb-5 aspect-[16/10] overflow-hidden border-b border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-muted))]">
      <img src={imageSrc} alt="" width="640" height="400" loading="lazy" decoding="async" class="h-full w-full object-cover" />
    </div>
  )}
  <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))]">{year} · {org || 'Award'}</p>
  <h3 class="mt-3 font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">{name}</h3>
  <p class="mt-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">{category}</p>
  <p class="mt-3 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-subtle))]">Project: {project}</p>
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-5 inline-block font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] hover:underline"
    >
      View award →
    </a>
  )}
</div>
