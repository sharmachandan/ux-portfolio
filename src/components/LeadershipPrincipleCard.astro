---
interface Props {
  title: string;
  description: string;
  example?: string;
}

const { title, description, example } = Astro.props;
---

<div class="rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-6 transition-all duration-[var(--transition-base)] hover:border-[rgb(var(--color-accent))]/40 hover:shadow-glow">
  <h3 class="font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">{title}</h3>
  <p class="mt-2 text-[rgb(var(--color-text-muted))] leading-relaxed">{description}</p>
  {example && (
    <blockquote class="mt-4 border-l-2 border-[rgb(var(--color-accent))]/50 pl-4 italic text-[rgb(var(--color-text-muted))]">
      {example}
    </blockquote>
  )}
</div>
