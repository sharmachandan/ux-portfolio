---
interface Props {
  slug: string;
  title: string;
  company: string;
  outcome: string;
  role: string;
  image?: string;
  problem?: string;
  impactCategories?: string[];
  featured?: boolean;
}

const { slug, title, company, outcome, role, image, problem, impactCategories = [], featured = false } = Astro.props;
---

<a
  href={`/case-studies/${slug}/`}
  class={`group block overflow-hidden border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] transition-all duration-[var(--transition-base)] hover:-translate-y-1 hover:border-[rgb(var(--color-accent-muted))]/30 hover:shadow-md ${
    featured ? 'md:col-span-2' : ''
  }`}
>
  {image && (
    <div class="aspect-video overflow-hidden bg-[rgb(var(--color-border))]/30">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}
  <div class="p-6">
    <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))]">{company}</p>
    <h3 class={`mt-3 font-display font-semibold text-[rgb(var(--color-text))] ${featured ? 'text-display-sm' : 'text-lg'}`}>
      {title}
    </h3>
    {problem && (
      <p class={`mt-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))] ${featured ? 'line-clamp-3 max-w-2xl' : 'line-clamp-2'}`}>
        {problem}
      </p>
    )}
    <p class={`mt-4 ${featured ? 'font-mono text-[0.66rem] uppercase tracking-[0.18em]' : 'text-sm font-medium'} text-[rgb(var(--color-accent))]`}>
      {outcome}
    </p>
    {featured && (
      <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-subtle))]">
        <span>{role}</span>
        {impactCategories.slice(0, 2).map((cat) => (
          <span class="border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-2 py-1 text-[0.58rem] text-[rgb(var(--color-accent-muted))]">
            {cat}
          </span>
        ))}
      </div>
    )}
    {!featured && (
      <p class="mt-2 font-mono text-[0.62rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-subtle))]">{role}</p>
    )}
    {!featured && impactCategories.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {impactCategories.map((cat) => (
          <span
            class="border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-2 py-1 font-mono text-[0.58rem] uppercase tracking-[0.14em] text-[rgb(var(--color-accent-muted))]"
          >
            {cat}
          </span>
        ))}
      </div>
    )}
    <p class={`font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] transition-colors group-hover:text-[rgb(var(--color-accent))] ${featured ? 'mt-6' : 'mt-5'}`}>
      Read case study →
    </p>
  </div>
</a>
