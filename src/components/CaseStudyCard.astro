---
interface Props {
  slug: string;
  title: string;
  company: string;
  outcome: string;
  role: string;
  image?: string;
  problem?: string;
  impactCategories?: string[];
  featured?: boolean;
}

const { slug, title, company, outcome, role, image, problem, impactCategories = [], featured = false } = Astro.props;
---

<a
  href={`/case-studies/${slug}/`}
  class={`block overflow-hidden rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] transition-all duration-[var(--transition-base)] hover:border-[rgb(var(--color-accent))]/40 hover:shadow-glow ${
    featured ? 'md:col-span-2' : ''
  }`}
>
  {image && (
    <div class="aspect-video overflow-hidden bg-[rgb(var(--color-border))]/30">
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}
  <div class="p-6">
    <p class="text-sm font-medium text-[rgb(var(--color-accent))]">{company}</p>
    <h3 class={`mt-2 font-display font-semibold text-[rgb(var(--color-text))] ${featured ? 'text-display-sm' : 'text-lg'}`}>
      {title}
    </h3>
    {problem && <p class="mt-1 text-sm text-[rgb(var(--color-text-muted))] line-clamp-1">{problem}</p>}
    <p class="mt-2 text-sm font-medium text-[rgb(var(--color-accent))]">{outcome}</p>
    <p class="mt-1 text-xs text-[rgb(var(--color-text-muted))]">{role}</p>
    {impactCategories.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {impactCategories.map((cat) => (
          <span
            class="rounded-full bg-[rgb(var(--color-accent))]/10 px-2 py-0.5 text-xs font-medium text-[rgb(var(--color-accent))]"
          >
            {cat}
          </span>
        ))}
      </div>
    )}
    <p class="mt-4 text-sm font-medium text-[rgb(var(--color-accent))] transition-colors group-hover:text-[rgb(var(--color-accent))]/80">
      Read case study →
    </p>
  </div>
</a>
