---
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  date: Date;
  coverImage?: string;
}

const { slug, title, excerpt, date, coverImage } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${slug}/`}
  class="group block overflow-hidden border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] transition-all duration-[var(--transition-base)] hover:-translate-y-1 hover:border-[rgb(var(--color-accent-muted))]/30 hover:shadow-md"
>
  {coverImage && (
    <div class="aspect-video overflow-hidden bg-[rgb(var(--color-border))]/30">
      <img
        src={coverImage}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>
  )}
  <div class="p-6">
    <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-text-subtle))]">{formattedDate}</p>
    <h3 class="mt-3 font-display text-display-sm font-semibold text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-accent-muted))]">
      {title}
    </h3>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">{excerpt}</p>
    <p class="mt-5 font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))]">Read more →</p>
  </div>
</a>
