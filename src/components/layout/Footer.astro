---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto border-t border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))]">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <div>
        <p class="font-display text-lg font-bold text-[rgb(var(--color-accent-muted))]">
          Chandan Sharma
        </p>
        <p class="mt-2 font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-text-subtle))]">
          © {currentYear} Design portfolio
        </p>
      </div>
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-text-subtle))]">
        Strategy · Systems · Experience Design
      </p>
      <div class="flex flex-wrap gap-x-6 gap-y-3">
        <a href="/case-studies/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          Case Studies
        </a>
        <a href="/resume/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          Resume
        </a>
        <a href="/about/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          About
        </a>
        <a href="/leadership/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          Leadership
        </a>
        <a href="/awards/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          Awards
        </a>
        <a href="/blog/" class="font-mono text-[0.68rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-muted))] transition-colors hover:text-[rgb(var(--color-accent-muted))]">
          Blog
        </a>
      </div>
    </div>
  </div>
</footer>
