---
interface Props {
  logoUrl?: string | null;
}

const { logoUrl } = Astro.props;
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/case-studies/', label: 'Case Studies' },
  { href: '/resume/', label: 'Resume' },
  { href: '/about/', label: 'About' },
  { href: '/leadership/', label: 'Leadership' },
  { href: '/awards/', label: 'Awards' },
  { href: '/blog/', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 border-b border-[rgb(var(--color-border))] glass-header">
  <nav class="mx-auto flex h-24 max-w-6xl items-center justify-between gap-6 px-6">
    <a href="/" class="flex h-full items-center transition-opacity hover:opacity-80" aria-label="Home">
      {logoUrl ? (
        <img src={logoUrl} alt="" class="h-[5.0625rem] max-h-full w-auto max-w-[270px] object-contain object-left" />
      ) : (
        <span class="font-display text-xl font-bold tracking-tight text-[rgb(var(--color-accent-muted))]">Chandan Sharma</span>
      )}
    </a>
    <button
      type="button"
      class="md:hidden rounded p-2 text-[rgb(var(--color-text-muted))] hover:bg-[rgb(var(--color-border))]/50"
      aria-label="Toggle menu"
      id="nav-toggle"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <ul class="nav-links hidden md:flex items-center gap-6" id="nav-links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`font-mono text-[0.68rem] uppercase tracking-[0.18em] transition-colors hover:text-[rgb(var(--color-accent-muted))] ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[rgb(var(--color-accent-muted))]'
                : 'text-[rgb(var(--color-text-subtle))]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="nav-mobile hidden md:hidden border-t border-[rgb(var(--color-border))] px-6 py-4" id="nav-mobile">
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`font-mono text-[0.72rem] uppercase tracking-[0.18em] ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[rgb(var(--color-accent-muted))]'
                : 'text-[rgb(var(--color-text-muted))]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      mobileNav.classList.toggle('hidden');
    });
  }
</script>
