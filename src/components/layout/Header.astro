---
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/case-studies/', label: 'Case Studies' },
  { href: '/about/', label: 'About' },
  { href: '/leadership/', label: 'Leadership' },
  { href: '/awards/', label: 'Awards' },
  { href: '/blog/', label: 'Blog' },
];
---

<header class="sticky top-0 z-50 border-b border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))/80] backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-semibold tracking-tight transition-opacity hover:opacity-80">
      Portfolio
    </a>
    <button
      type="button"
      class="md:hidden rounded p-2 text-[rgb(var(--color-text-muted))] hover:bg-[rgb(var(--color-border))]/50"
      aria-label="Toggle menu"
      id="nav-toggle"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <ul class="nav-links hidden md:flex items-center gap-8" id="nav-links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors hover:text-[rgb(var(--color-accent))] ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[rgb(var(--color-accent))]'
                : 'text-[rgb(var(--color-text-muted))]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="nav-mobile hidden md:hidden border-t border-[rgb(var(--color-border))] px-6 py-4" id="nav-mobile">
    <ul class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`text-sm font-medium ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[rgb(var(--color-accent))]'
                : 'text-[rgb(var(--color-text-muted))]'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      mobileNav.classList.toggle('hidden');
    });
  }
</script>
