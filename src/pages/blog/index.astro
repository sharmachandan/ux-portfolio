---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const sortedPosts = blogPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<PageLayout
  title="Blog | Design Leader"
  description="Thoughts on design leadership, strategy, and shipping with impact."
>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <header>
      <h1 class="font-display text-display-lg font-bold text-[rgb(var(--color-text))]">
        Blog
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-[rgb(var(--color-text-muted))]">
        Thoughts on design leadership, strategy, and shipping with impact.
      </p>
    </header>

    {sortedPosts.length > 0 ? (
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.map((post) => (
          <BlogCard
            slug={post.slug}
            title={post.data.title}
            excerpt={post.data.excerpt}
            date={post.data.date}
            coverImage={post.data.coverImage}
          />
        ))}
      </div>
    ) : (
      <div class="mt-12 rounded-2xl border border-dashed border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))]/50 p-16 text-center">
        <h2 class="font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">Coming Soon</h2>
        <p class="mt-4 text-[rgb(var(--color-text-muted))]">
          Blog posts will be added here. Check back for thoughts on design leadership, team building,
          strategic design, and lessons from 20 years in the field.
        </p>
      </div>
    )}
  </div>
</PageLayout>
