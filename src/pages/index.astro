---
import PageLayout from '../layouts/PageLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import LeadershipPrincipleCard from '../components/LeadershipPrincipleCard.astro';
import { leadershipPrinciples } from '../data/leadership-principles';
import { awards } from '../data/awards';
import { getBlogPosts } from '../lib/blog';
import {
  getHomePage,
  getLeadershipPage,
  imageUrlFor,
} from '../lib/sanity-pages';
import { getCaseStudySummaries } from '../lib/case-studies';

const homePage = await getHomePage();
const leadershipPage = await getLeadershipPage();

const caseStudies = await getCaseStudySummaries();
const sortCaseStudies = <T extends { sortOrder?: number; title: string }>(items: T[]) =>
  [...items].sort((a, b) => (a.sortOrder ?? Number.MAX_SAFE_INTEGER) - (b.sortOrder ?? Number.MAX_SAFE_INTEGER) || a.title.localeCompare(b.title));

const featuredCaseStudies = sortCaseStudies(caseStudies.filter((c) => c.featured));
const otherCaseStudies = sortCaseStudies(caseStudies.filter((c) => !c.featured));

const recentBlogPosts = await getBlogPosts(3);

// Fallback content
const hero = {
  headline: homePage?.heroHeadline ?? 'Design Leader',
  subtitle: homePage?.heroSubtitle ?? 'Fortune 1 Retailer',
  description: homePage?.heroDescription ?? '20 years of UX leadership. Strategic design that drives business outcomes. Multiple international design awards. Building teams and systems that ship with impact.',
  image:
    homePage?.heroImage
      ? imageUrlFor(homePage.heroImage)
      : (import.meta.env.PUBLIC_HERO_IMAGE ?? '/images/hero-pov.jpg'),
  ctaPrimaryLabel: homePage?.ctaPrimaryLabel ?? 'View Case Studies',
  ctaPrimaryHref: homePage?.ctaPrimaryHref ?? '/case-studies/',
  ctaSecondaryLabel: homePage?.ctaSecondaryLabel ?? 'About Me',
  ctaSecondaryHref: homePage?.ctaSecondaryHref ?? '/about/',
};
const featuredWork = {
  title: homePage?.featuredWorkTitle ?? 'Featured Work',
  description: homePage?.featuredWorkDescription ?? 'Selected case studies demonstrating strategic impact and leadership.',
  linkLabel: homePage?.featuredWorkLinkLabel ?? 'View all case studies',
};
const awardsSection = {
  title: homePage?.awardsTitle ?? 'International Design Awards',
  description: homePage?.awardsDescription ?? 'Recognized by Awwwards, FWA, Red Dot, Webby, and IDEA for design excellence.',
  linkLabel: homePage?.awardsLinkLabel ?? 'View all awards',
};
const leadershipSection = {
  title: homePage?.leadershipTitle ?? 'Leadership Principles',
  description: homePage?.leadershipDescription ?? 'The beliefs that guide how I lead design teams and shape product strategy.',
  linkLabel: homePage?.leadershipLinkLabel ?? 'View all principles',
};
const principles = leadershipPage?.principles?.length
  ? leadershipPage.principles
  : leadershipPrinciples;
const blogSection = {
  title: homePage?.blogTitle ?? 'Blog',
  description: homePage?.blogDescription ?? 'Thoughts on design leadership, strategy, and shipping with impact.',
  emptyMessage: homePage?.blogEmptyMessage ?? 'Blog posts coming soon. Check back for thoughts on design leadership and strategy.',
};
const contact = {
  title: homePage?.contactTitle ?? "Let's Connect",
  description: homePage?.contactDescription ?? 'Open to speaking, advisory, and consulting opportunities. Reach out to discuss design leadership, team building, or how we can collaborate.',
  buttonLabel: homePage?.contactButtonLabel ?? 'Get in Touch',
  email: homePage?.contactEmail ?? 'hello@example.com',
};
---

<PageLayout title={`${hero.headline} | UX Portfolio`} description={hero.description}>
  <div class="mx-auto max-w-6xl px-6 py-10 md:py-14">
    <!-- Hero -->
    <section class="animate-fade-in relative overflow-hidden rounded-2xl border border-[rgb(var(--color-border))]">
      <!-- POV as stacked image on small, background on lg -->
      <div class="aspect-[4/3] lg:absolute lg:inset-0 lg:aspect-auto">
        <img
          src={hero.image}
          alt=""
          class="h-full w-full object-cover object-center"
          width="1200"
          height="600"
          aria-hidden
        />
      </div>
      <!-- Overlay gradient for text readability on large breakpoints -->
      <div
        class="hidden lg:block lg:absolute lg:inset-0 lg:bg-gradient-to-r lg:from-[rgb(var(--color-bg))]/95 lg:via-[rgb(var(--color-bg))]/80 lg:via-35% lg:to-transparent"
        aria-hidden
      />
      <!-- Content: stacked on small, overlaid left on lg -->
      <div class="relative flex flex-col justify-center px-6 py-12 lg:min-h-[24rem] lg:max-w-[34rem] lg:px-8 lg:py-14">
        <h1 class="font-display text-hero font-bold text-[rgb(var(--color-text))]">
          {hero.headline}
        </h1>
        <p class="mt-4 text-xl font-medium text-[rgb(var(--color-accent))]">
          {hero.subtitle}
        </p>
        <p class="mt-6 text-lg leading-relaxed text-[rgb(var(--color-text-muted))]">
          {hero.description}
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a
            href={hero.ctaPrimaryHref}
            class="rounded-lg bg-[rgb(var(--color-accent))] px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
          >
            {hero.ctaPrimaryLabel}
          </a>
          <a
            href={hero.ctaSecondaryHref}
            class="rounded-lg border border-[rgb(var(--color-border))] px-6 py-3 text-sm font-medium text-[rgb(var(--color-text))] transition-colors hover:border-[rgb(var(--color-accent))]/50 hover:text-[rgb(var(--color-accent))]"
          >
            {hero.ctaSecondaryLabel}
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Case Studies -->
    <section class="mt-24">
      <h2 class="font-display text-display font-bold text-[rgb(var(--color-text))]">
        {featuredWork.title}
      </h2>
      <p class="mt-3 max-w-2xl text-[rgb(var(--color-text-muted))]">
        {featuredWork.description}
      </p>
      <div class="mt-8 grid gap-8 md:grid-cols-2">
        {featuredCaseStudies.map((study) => (
          <CaseStudyCard
            slug={study.slug}
            title={study.title}
            company={study.company}
            outcome={study.outcome}
            role={study.role}
            image={study.image}
            problem={study.problem}
            impactCategories={study.impactCategories}
            featured={true}
          />
        ))}
      </div>
      {otherCaseStudies.length > 0 && (
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {otherCaseStudies.slice(0, 3).map((study) => (
            <CaseStudyCard
              slug={study.slug}
              title={study.title}
              company={study.company}
              outcome={study.outcome}
              role={study.role}
              image={study.image}
              problem={study.problem}
              impactCategories={study.impactCategories}
            />
          ))}
        </div>
      )}
      <div class="mt-10 text-center">
        <a
          href="/case-studies/"
          class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] hover:underline"
        >
          {featuredWork.linkLabel} →
        </a>
      </div>
    </section>

    <!-- Awards Teaser -->
    <section class="mt-28 rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-8 md:p-12">
      <h2 class="font-display text-display font-bold text-[rgb(var(--color-text))]">
        {awardsSection.title}
      </h2>
      <p class="mt-2 text-[rgb(var(--color-text-muted))]">
        {awardsSection.description}
      </p>
      <a
        href="/awards/"
        class="mt-6 inline-block font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] hover:underline"
      >
        {awardsSection.linkLabel} →
      </a>
    </section>

    <!-- Leadership Principles Preview -->
    <section class="mt-28">
      <h2 class="font-display text-display font-bold text-[rgb(var(--color-text))]">
        {leadershipSection.title}
      </h2>
      <p class="mt-2 text-[rgb(var(--color-text-muted))]">
        {leadershipSection.description}
      </p>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {principles.slice(0, 3).map((principle: { title: string; description: string; example: string }) => (
          <LeadershipPrincipleCard
            title={principle.title}
            description={principle.description}
            example={principle.example}
          />
        ))}
      </div>
      <div class="mt-10 text-center">
        <a
          href="/leadership/"
          class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] hover:underline"
        >
          {leadershipSection.linkLabel} →
        </a>
      </div>
    </section>

    <!-- Recent Blog Posts -->
    <section class="mt-20">
      <h2 class="font-display text-display font-bold text-[rgb(var(--color-text))]">
        {blogSection.title}
      </h2>
      <p class="mt-2 text-[rgb(var(--color-text-muted))]">
        {blogSection.description}
      </p>
      {recentBlogPosts.length > 0 ? (
        <div class:list={['mt-8 grid gap-6', recentBlogPosts.length === 1 ? 'max-w-xl' : recentBlogPosts.length === 2 ? 'md:grid-cols-2 max-w-4xl' : 'sm:grid-cols-2 lg:grid-cols-3']}>
          {recentBlogPosts.map((post: { slug: string; title: string; excerpt: string; date: Date }) => (
            <a
              href={`/blog/${post.slug}/`}
              class="block border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-6 transition-all duration-[var(--transition-base)] hover:-translate-y-1 hover:border-[rgb(var(--color-accent-muted))]/30 hover:shadow-md"
            >
              <p class="font-mono text-[0.62rem] uppercase tracking-[0.18em] text-[rgb(var(--color-text-subtle))]">
                {post.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <h3 class="mt-2 text-lg font-semibold text-[rgb(var(--color-text))]">
                {post.title}
              </h3>
              <p class="mt-2 line-clamp-2 text-sm text-[rgb(var(--color-text-muted))]">
                {post.excerpt}
              </p>
              <p class="mt-5 font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))]">
                Read more →
              </p>
            </a>
          ))}
        </div>
      ) : (
        <div class="mt-8 rounded-xl border border-dashed border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))]/50 p-12 text-center">
          <p class="text-[rgb(var(--color-text-muted))]">
            {blogSection.emptyMessage}
          </p>
          <a href="/blog/" class="mt-4 inline-block font-mono text-[0.68rem] uppercase tracking-[0.18em] text-[rgb(var(--color-accent-muted))] hover:underline">
            View blog →
          </a>
        </div>
      )}
    </section>

    <!-- Contact CTA -->
    <section class="mt-28 rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] p-8 md:p-12 text-center">
      <h2 class="font-display text-display font-bold text-[rgb(var(--color-text))]">
        {contact.title}
      </h2>
      <p class="mt-2 max-w-xl mx-auto text-[rgb(var(--color-text-muted))]">
        {contact.description}
      </p>
      <a
        href={`mailto:${contact.email}`}
        class="mt-6 inline-block rounded-lg bg-[rgb(var(--color-accent))] px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        {contact.buttonLabel}
      </a>
    </section>
  </div>
</PageLayout>
