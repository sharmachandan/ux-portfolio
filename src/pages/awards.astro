---
import PageLayout from '../layouts/PageLayout.astro';
import AwardCard from '../components/AwardCard.astro';
import { awards } from '../data/awards';
import { getAwardsPage } from '../lib/sanity-pages';

const awardsPage = await getAwardsPage();

const title = awardsPage?.title ?? 'Awards & Recognition';
const description = awardsPage?.description ?? 'Recognized internationally for design excellence across e-commerce, mobile, and digital experiences.';
const awardsList = awardsPage?.awards?.length
  ? awardsPage.awards
  : awards;

const sortedAwards = [...awardsList].sort((a: { year: number }, b: { year: number }) => b.year - a.year);
---

<PageLayout title={`${title} | Design Leader`} description={description}>
  <div class="mx-auto max-w-6xl px-6 py-16">
    <header>
      <h1 class="font-display text-display-lg font-bold text-[rgb(var(--color-text))]">
        {title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-[rgb(var(--color-text-muted))]">
        {description}
      </p>
    </header>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {sortedAwards.map((award: { name: string; year: number; category: string; project: string; org: string; link?: string; imageSrc?: string }) => (
        <AwardCard
          name={award.name}
          year={award.year}
          category={award.category}
          project={award.project}
          org={award.org}
          link={award.link}
          imageSrc={award.imageSrc}
        />
      ))}
    </div>
  </div>
</PageLayout>
