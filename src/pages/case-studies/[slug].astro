---
import PageLayout from '../../layouts/PageLayout.astro';
import { PortableText } from 'astro-portabletext';
import { getCollection } from 'astro:content';
import ClosingLoopCaseStudy from '../../components/case-studies/ClosingLoopCaseStudy.astro';
import JustGoCaseStudy from '../../components/case-studies/JustGoCaseStudy.astro';
import { getCaseStudyBySlugFromSanity, imageUrlFor } from '../../lib/sanity-pages';
import { getCaseStudySummaries } from '../../lib/case-studies';

export async function getStaticPaths() {
  const studies = await getCaseStudySummaries();
  return studies.map((study) => ({ params: { slug: study.slug } }));
}

const { slug } = Astro.params;
const protectedCaseStudySlugs = ['just-go-0-to-1', 'closing-the-loop-iterative-design'];
const isLightProtectedCaseStudy = typeof slug === 'string' && protectedCaseStudySlugs.includes(slug);
const collection = await getCollection('case-studies');
const localStudy = collection.find((entry) => entry.slug === slug);

let title = '';
let company = '';
let outcome = '';
let role = '';
let problem = '';
let impactCategories: string[] = [];
let coverImage = '';
let body: any[] | null = null;
let ContentComponent: any = null;
let template = '';
let isLocalStudy = false;

if (localStudy) {
  isLocalStudy = true;
  title = localStudy.data.title;
  company = localStudy.data.company;
  outcome = localStudy.data.outcome;
  role = localStudy.data.role;
  problem = localStudy.data.problem ?? '';
  impactCategories = localStudy.data.impactCategories ?? [];
  coverImage = localStudy.data.image ?? '';
  template = localStudy.data.template ?? '';

  if (!['just-go', 'closing-loop'].includes(template)) {
    const rendered = await localStudy.render();
    ContentComponent = rendered.Content;
  }
} else {
  const study = await getCaseStudyBySlugFromSanity(slug!);
  if (study) {
    title = study.title;
    company = study.company;
    outcome = study.outcome;
    role = study.role;
    problem = study.problem ?? '';
    impactCategories = study.impactCategories ?? [];
    coverImage = study.coverImage ? imageUrlFor(study.coverImage) : '';
    body = study.body;
  }
}

const allStudies = await getCaseStudySummaries();
const allSlugs = allStudies.map((study) => ({ slug: study.slug, title: study.title }));
const relatedStudies = allSlugs.filter((s) => s.slug !== slug).slice(0, 2);
---

<PageLayout title={`${title} | Case Study`} description={problem || outcome}>
  {isLightProtectedCaseStudy ? (
    <div class="case-study-light-protected">
      <div class="case-study-light-protected__gate" data-case-study-gate>
        <div class="mx-auto max-w-2xl px-6 py-16">
          <header>
            <p class="font-mono text-[0.625rem] uppercase tracking-[0.22em] text-[rgb(var(--color-accent-muted))]">Private case study</p>
            <h1 class="mt-3 font-display text-display-lg font-bold text-[rgb(var(--color-text))]">{title}</h1>
            <p class="mt-4 text-[rgb(var(--color-text-muted))]">
              Enter the password to view this case study.
            </p>
          </header>

          <form class="mt-10 space-y-4" data-case-study-form>
            <label class="block">
              <span class="sr-only">Password</span>
              <input
                id="case-study-password"
                type="password"
                autocomplete="current-password"
                placeholder="Password"
                class="w-full rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] px-4 py-3 font-mono text-sm text-[rgb(var(--color-text))] focus:outline-none focus:ring-2 focus:ring-[rgb(var(--color-accent-muted))]/30"
              />
            </label>

            <button
              type="submit"
              class="w-full rounded-lg bg-[rgb(var(--color-accent))] px-6 py-3 font-mono text-[0.68rem] uppercase tracking-[0.18em] text-white transition-opacity hover:opacity-90"
            >
              Unlock
            </button>

            <p class="hidden text-sm text-[rgb(var(--color-accent-muted))]" data-case-study-error aria-live="polite">
              Incorrect password.
            </p>
          </form>
        </div>
      </div>

      <div class="case-study-light-protected__content" data-case-study-content style="display:none;">
        {template === 'just-go' ? (
          <JustGoCaseStudy />
        ) : template === 'closing-loop' ? (
          <ClosingLoopCaseStudy />
        ) : (
          <article class="mx-auto max-w-4xl px-6 py-16">
            {coverImage && (
              <div class="-mx-6 mb-12 overflow-hidden border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] sm:mx-0">
                <img
                  src={coverImage}
                  alt={title}
                  class="w-full object-cover"
                  width="896"
                  height="504"
                />
              </div>
            )}
            <header class="mb-12">
              <p class="font-mono text-[0.625rem] uppercase tracking-[0.22em] text-[rgb(var(--color-accent-muted))]">{company}</p>
              <h1 class="mt-3 font-display text-display-lg font-bold text-[rgb(var(--color-text))]">
                {title}
              </h1>
              <p class="mt-4 text-xl font-medium text-[rgb(var(--color-accent-muted))]">{outcome}</p>
              <p class="mt-2 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-subtle))]">{role}</p>
              {impactCategories.length > 0 && (
                <div class="mt-5 flex flex-wrap gap-2">
                  {impactCategories.map((cat) => (
                    <span
                      class="inline-flex items-center border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] px-3 py-1 font-mono text-[0.625rem] uppercase tracking-[0.16em] text-[rgb(var(--color-accent-muted))]"
                    >
                      {cat}
                    </span>
                  ))}
                </div>
              )}
            </header>

            <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:font-semibold prose-headings:text-[rgb(var(--color-text))] prose-p:text-[rgb(var(--color-text-muted))] prose-a:text-[rgb(var(--color-accent-muted))] prose-a:no-underline hover:prose-a:underline prose-strong:text-[rgb(var(--color-text))]">
              {!isLocalStudy && body && body.length > 0 ? (
                <PortableText value={body} />
              ) : ContentComponent ? (
                <ContentComponent />
              ) : (
                <p>Case study not found.</p>
              )}
            </div>

            {relatedStudies.length > 0 && (
              <aside class="mt-16 border-t border-[rgb(var(--color-border))] pt-12">
                <h2 class="font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">Related Case Studies</h2>
                <ul class="mt-6 space-y-4">
                  {relatedStudies.map((s) => (
                    <li>
                      <a
                        href={`/case-studies/${s.slug}/`}
                        class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[rgb(var(--color-accent-muted))] hover:underline"
                      >
                        {s.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </aside>
            )}
          </article>
        )}
      </div>

      <script>
        const CASE_STUDY_PASSWORD = 'AI4Experience';
        const slug = {JSON.stringify(slug)};
        const unlockedKey = `case-study-unlocked:${String(slug)}`;

        const gateEl = document.querySelector('[data-case-study-gate]');
        const contentEl = document.querySelector('[data-case-study-content]');
        const formEl = document.querySelector('[data-case-study-form]');
        const inputEl = document.getElementById('case-study-password');
        const errorEl = document.querySelector('[data-case-study-error]');

        function unlock() {
          if (!contentEl) return;
          if (gateEl) gateEl.remove();
          contentEl.style.display = 'block';
        }

        function lock() {
          if (contentEl) contentEl.style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', () => {
          try {
            if (localStorage.getItem(unlockedKey) === '1') {
              unlock();
              return;
            }
          } catch {
            // Ignore storage failures; user can still unlock.
          }
          lock();

          if (!formEl || !inputEl) return;

          formEl.addEventListener('submit', (e) => {
            e.preventDefault();
            const value = inputEl.value || '';
            const ok = value === CASE_STUDY_PASSWORD;
            if (ok) {
              try {
                localStorage.setItem(unlockedKey, '1');
              } catch {
                // Ignore storage failures.
              }
              if (errorEl) errorEl.classList.add('hidden');
              unlock();
            } else {
              if (errorEl) errorEl.classList.remove('hidden');
            }
          });
        });
      </script>
    </div>
  ) : template === 'just-go' ? (
    <JustGoCaseStudy />
  ) : template === 'closing-loop' ? (
    <ClosingLoopCaseStudy />
  ) : (
    <article class="mx-auto max-w-4xl px-6 py-16">
      {coverImage && (
        <div class="-mx-6 mb-12 overflow-hidden border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] sm:mx-0">
          <img
            src={coverImage}
            alt={title}
            class="w-full object-cover"
            width="896"
            height="504"
          />
        </div>
      )}
      <header class="mb-12">
        <p class="font-mono text-[0.625rem] uppercase tracking-[0.22em] text-[rgb(var(--color-accent-muted))]">{company}</p>
        <h1 class="mt-3 font-display text-display-lg font-bold text-[rgb(var(--color-text))]">
          {title}
        </h1>
        <p class="mt-4 text-xl font-medium text-[rgb(var(--color-accent-muted))]">{outcome}</p>
        <p class="mt-2 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[rgb(var(--color-text-subtle))]">{role}</p>
        {impactCategories.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {impactCategories.map((cat) => (
              <span
                class="inline-flex items-center border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-elevated))] px-3 py-1 font-mono text-[0.625rem] uppercase tracking-[0.16em] text-[rgb(var(--color-accent-muted))]"
              >
                {cat}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:font-semibold prose-headings:text-[rgb(var(--color-text))] prose-p:text-[rgb(var(--color-text-muted))] prose-a:text-[rgb(var(--color-accent-muted))] prose-a:no-underline hover:prose-a:underline prose-strong:text-[rgb(var(--color-text))]">
        {!isLocalStudy && body && body.length > 0 ? (
          <PortableText value={body} />
        ) : ContentComponent ? (
          <ContentComponent />
        ) : (
          <p>Case study not found.</p>
        )}
      </div>

      {relatedStudies.length > 0 && (
        <aside class="mt-16 border-t border-[rgb(var(--color-border))] pt-12">
          <h2 class="font-display text-display-sm font-semibold text-[rgb(var(--color-text))]">Related Case Studies</h2>
          <ul class="mt-6 space-y-4">
            {relatedStudies.map((s) => (
              <li>
                <a
                  href={`/case-studies/${s.slug}/`}
                  class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-[rgb(var(--color-accent-muted))] hover:underline"
                >
                  {s.title}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </article>
  )}
</PageLayout>
