---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  faviconUrl?: string | null;
}

const { title, description = "Design Leader portfolio—20 years of UX leadership, strategic design, and award-winning work.", faviconUrl } = Astro.props;
const favicon = faviconUrl || '/favicon.svg';
const faviconLower = favicon.toLowerCase();
const faviconType =
  faviconLower.includes('.svg') ? 'image/svg+xml'
  : faviconLower.includes('.png') ? 'image/png'
  : faviconLower.includes('.ico') ? 'image/x-icon'
  : 'image/png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type={faviconType} href={favicon} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))] font-sans mesh-gradient">
    <div class="flex min-h-screen flex-col">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  body {
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Libre Baskerville', Georgia, serif;
  }
</style>
