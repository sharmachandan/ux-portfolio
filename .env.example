# Sanity CMS – create a project at https://sanity.io/manage
# Run: npx sanity login  then  npx sanity init  to create project and get these values
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production

# Optional: local hero POV image path (e.g. /images/hero-pov.jpg) used when no Sanity image is set
# PUBLIC_HERO_IMAGE=/images/hero-pov.jpg

# Sanity Studio (required for npm run studio)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
